#include<iostream>
#include<string>
 
using namespace std;
class Student {
public:
string name;
int roll;
int marks;

Student(string n,int r,
int m){
    name= n;
    roll= r;
    marks= m;

}
char getGrade(){
    if(marks >=90)return
'A';
if(marks >=80)return
'B';
if(marks >=70)return 
'C';
if(marks >=60)return
'D';
   return 'F';

}
void show(){
cout<<"Student Name:"<<name<<endl;
cout<<"Roll Number:"<<roll<<endl;
cout<<"Marks:"<<marks<<endl;
cout<<"Grade:"<<getGrade()<<endl;
           }

};
int main(){
    Student s1("Muhammad Kaif",45,90);
    Student s2("Ibrahim",56,89);

    s1.show();
    s2.show();

    return 0;
}
